    </answer>
    <answer fraction="0" format="html">
      <text>&lt;p&gt;類別圖&lt;/p&gt;</text>
    </answer>
    <answer fraction="0" format="html">
      <text>&lt;p&gt;元件圖&lt;/p&gt;</text>
